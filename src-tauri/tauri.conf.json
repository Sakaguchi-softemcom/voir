{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Voir",
  "version": "0.1.0",
  "identifier": "com.voir.app",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Voir",
        "width": 1200,
        "height": 800,
        "minWidth": 640,
        "minHeight": 480,
        "center": true,
        "decorations": true,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkdn", "mkd", "mdwn"],
        "mimeType": "text/markdown",
        "description": "Markdown Document"
      }
    ]
  },
  "plugins": {}
}
